# Freshdesk API Configuration
# Copy this file to .env and fill in your values

# Your Freshdesk subdomain (e.g. "yourcompany" for yourcompany.freshdesk.com)
FRESHDESK_DOMAIN=

# API key from Profile Settings in your Freshdesk portal
FRESHDESK_API_KEY=

# Server port (optional, defaults to 3000)
PORT=3000
